# Copy this file to `.env` and fill in the keys you want to use.
# Jarvis routes each turn to a model by difficulty (see config.py ROUTING).
# You only need keys for the providers your routing table actually uses.

# ── Recommended free default: Google Gemini (reflex/workhorse/vision tiers) ──
# Free key from https://aistudio.google.com  →  Get API key
GEMINI_API_KEY=

# ── Claude — used for the "deep" tier (hard reasoning). Optional. ──
# Pay-as-you-go key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Other OpenAI-compatible providers (optional) ──
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# (Ollama needs no key — just run it locally on http://localhost:11434)

# ── Optional: ElevenLabs British Jarvis voice (coming soon) ──
# ELEVENLABS_API_KEY=
